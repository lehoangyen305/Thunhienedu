<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hiểu Con Hơn - Đăng Ký Tham Gia</title>
    <style>
        :root {
            --primary: #1e40af;
            --primary-light: #3b82f6;
            --accent: #06b6d4;
            --text-dark: #1f2937;
            --bg-light: #f9fafb;
            --white: #ffffff;
            --success: #10b981;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: 40px auto;
            background: var(--white);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        h2 {
            color: var(--primary);
            text-align: center;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
        }

        input, select, textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 16px;
        }

        button {
            width: 100%;
            padding: 14px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
        }

        button:hover {
            background-color: var(--primary-light);
        }

        #loading-state {
            display: none;
            text-align: center;
            padding: 20px;
        }

        #success-state {
            display: none;
            text-align: center;
            color: var(--success);
            padding: 20px;
        }
    </style>
</head>
<body>

<div class="container">
    <div id="form-container">
        <h2>ĐĂNG KÝ "HIỂU CON HƠN"</h2>
        <form id="registrationForm">
            <div class="form-group">
                <label>Họ và Tên</label>
                <input type="text" name="hoTen" placeholder="Nguyễn Văn A" required>
            </div>
            
            <div class="form-group">
                <label>Số điện thoại</label>
                <input type="tel" name="soDienThoai" placeholder="090..." required>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="email@gmail.com" required>
            </div>

            <div class="form-group">
                <label>Độ tuổi của con</label>
                <select name="tuoi" required>
                    <option value="">Chọn độ tuổi</option>
                    <option value="Dưới 3 tuổi">Dưới 3 tuổi</option>
                    <option value="3 - 6 tuổi">3 - 6 tuổi</option>
                    <option value="6 - 12 tuổi">6 - 12 tuổi</option>
                    <option value="Trên 12 tuổi">Trên 12 tuổi</option>
                </select>
            </div>

            <div class="form-group">
                <label>Vấn đề bạn đang gặp phải với con</label>
                <textarea name="vanDe" rows="4" placeholder="Chia sẻ thêm về khó khăn của bạn..."></textarea>
            </div>

            <button type="submit" id="submitBtn">GỬI ĐĂNG KÝ</button>
        </form>
    </div>

    <div id="loading-state">
        <p>🔄 Đang gửi thông tin, vui lòng đợi...</p>
    </div>

    <div id="success-state">
        <h3>🎉 Đăng ký thành công!</h3>
        <p>Cảm ơn bạn. Chúng tôi sẽ liên hệ sớm nhất.</p>
    </div>
</div>

<script>
    // ============ CẤU HÌNH (THAY THẾ TẠI ĐÂY) ============
    const CONFIG = {
        appScriptUrl: 'https://script.google.com/macros/s/AKfycbxaltG4f7JffsXM9PMu9T9mFSxFc8ibK8MmE42xaaSjeN-KayJEBxrXdaQ8JAlJJ8im/exec' 
    };

    const form = document.getElementById('registrationForm');
    const formContainer = document.getElementById('form-container');
    const loadingState = document.getElementById('loading-state');
    const successState = document.getElementById('success-state');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        formContainer.style.display = 'none';
        loadingState.style.display = 'block';

        const formData = new FormData(form);
        
        // Khớp chính xác với cấu trúc Google Sheet của bạn (Cột A -> H)
        const data = {
            hoTen: formData.get('hoTen'),
            soDienThoai: formData.get('soDienThoai'),
            email: formData.get('email'),
            tuoi: formData.get('tuoi'), // Sẽ đưa vào cột 'Khoá học'
            vanDe: formData.get('vanDe'), // Sẽ đưa vào cột 'Lời nhắn'
            ngayDangKy: new Date().toLocaleString('vi-VN', {timeZone: 'Asia/Ho_Chi_Minh'})
        };

        try {
            await fetch(CONFIG.appScriptUrl, {
                method: 'POST',
                mode: 'no-cors', // Cần thiết để tránh lỗi CORS với AppScript
                cache: 'no-cache',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            // Sau khi gửi thành công
            loadingState.style.display = 'none';
            successState.style.display = 'block';
            
        } catch (error) {
            console.error('Error:', error);
            alert('Có lỗi xảy ra khi kết nối. Hãy kiểm tra URL AppScript của bạn.');
            formContainer.style.display = 'block';
            loadingState.style.display = 'none';
        }
    });
</script>

</body>
</html>
